# ── TxReceipts environment configuration ───────────────────────────────
# Copy this file to `.env.local` and fill in your free API keys, then
# restart the dev server. On a host (Vercel/Netlify) set these as env vars.
#
# NOTE: these are NEXT_PUBLIC_* vars, so they are bundled into the browser.
# That is expected for this client-only app — use read-only block-explorer
# keys, and set usage/domain limits in each provider's dashboard.

# Etherscan V2 API key — ONE key covers Ethereum, Polygon and Sepolia.
# Required for EVM transaction scanning.
# Free key (5 req/s, 100k/day): https://etherscan.io/myapikey
NEXT_PUBLIC_ETHERSCAN_API_KEY=

# Helius API key — OPTIONAL, only needed to scan Solana addresses.
# Free key: https://dashboard.helius.dev
NEXT_PUBLIC_HELIUS_API_KEY=

# No key required for:
#   • Bitcoin transactions & fees  — mempool.space
#   • Native USD prices            — CoinGecko
#   • Ticker prices                — Binance
#   • Live ETH gas                 — publicnode / drpc RPC
